    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.0.0",
    "cache-manager": "^6.0.0",
    "class-transformer": "^0.5.1",
