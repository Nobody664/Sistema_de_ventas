{
  "compilerOptions": {
    /* Lenguaje */
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",

    /* Directorios */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Output */
    "sourceMap": true,
    "removeComments": true,
    "declaration": false,

    /* Decoradores (NestJS / Prisma) */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Compatibilidad */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Tipado */
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,

    /* Performance */
    "skipLibCheck": true,
    "incremental": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts"
  ]
}