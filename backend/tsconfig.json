{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],

    "declaration": false,
    "emitDeclarationOnly":false,
    "sourceMap": true,
    "removeComments": true,

    "rootDir": "./src",
    "outDir": "./dist",
    

    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "skipLibCheck": true,
    "incremental": true,

    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },

    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "prisma","*.ts", "test"]
} 