NODE_ENV=development
PORT=4000
API_PREFIX=api
APP_NAME=Ventas SaaS API

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ventas_saas?schema=public

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
REDIS_URL=redis://localhost:6379

S3_BUCKET=ventas-saas-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

STRIPE_SECRET_KEY=change-me
STRIPE_WEBHOOK_SECRET=change-me
MERCADOPAGO_ACCESS_TOKEN=change-me
PAYPAL_CLIENT_ID=change-me
PAYPAL_CLIENT_SECRET=change-me
