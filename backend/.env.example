NODE_ENV=development
PORT=4000
API_PREFIX=api
APP_NAME=Ventas SaaS API


# =============================================================================
# DATABASE POSTGRES LOCAL
# =============================================================================
DATABASE_URL="postgresql://postgres:123456@localhost:5432/multi-saass"


# =============================================================================
# JWT - No usar en producción
# =============================================================================
JWT_ACCESS_SECRET="access_secret_ventas_2026"
JWT_REFRESH_SECRET="refresh_secret_ventas_2026"
