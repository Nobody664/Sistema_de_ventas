JWT_REFRESH_TTL=30d


# =============================================================================
# REDIS (Render/Upstash - producción)
# =============================================================================
# Desarrollo local:
# REDIS_URL="redis://127.0.0.1:6379"
# Render/Upstash (producción):
# REDIS_URL="rediss://default:xxxxx@nombre-upstash.upstash.io:6379"


# =============================================================================
# AWS S3
# =============================================================================
S3_BUCKET="ventas-saas-assets"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="change-me"
S3_SECRET_ACCESS_KEY="change-me"


# =============================================================================
# PASARELAS DE PAGO
# =============================================================================
