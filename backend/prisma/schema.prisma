generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  PAST_DUE
  INACTIVE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum PaymentProvider {
  STRIPE
  MERCADOPAGO
  PAYPAL
  CASH
  CARD
  TRANSFER
  YAPE
  PLIN
}

enum GlobalRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum MembershipRole {
  COMPANY_ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
  PENDING
}

enum NotificationType {
  SALE
  PAYMENT
  INVENTORY
  SUBSCRIPTION
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
  WHATSAPP
}

enum PlanUpgradeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CheckoutRequestStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  globalRole   GlobalRole @default(USER)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  memberships Membership[]
  employee    Employee?
  notifications Notification[]
  auditLogs   AuditLog[]

  @@map("users")
}

model Company {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  legalName   String?       @map("legal_name")
  taxId       String?       @map("tax_id")
  address     String?
  email       String?
  phone       String?
  timezone    String        @default("America/Lima")
  currency    String        @default("PEN")
  status      CompanyStatus @default(TRIAL)
  trialEndsAt DateTime?     @map("trial_ends_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  subscriptions       Subscription[]
  memberships         Membership[]
  customers           Customer[]
  products            Product[]
  categories          Category[]
  sales               Sale[]
  employees           Employee[]
  invoices            InvoiceTemplate[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  paymentSettings     PaymentSetting[]
  inventoryMovements  InventoryMovement[]
  planUpgradeRequests PlanUpgradeRequest[]
  checkoutRequests   CheckoutRequest[]

  @@map("companies")
}

model Plan {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  description  String?
  priceMonthly Decimal      @map("price_monthly") @db.Decimal(10, 2)
  priceYearly  Decimal      @map("price_yearly") @db.Decimal(10, 2)
  billingCycle BillingCycle @default(MONTHLY)
  maxUsers     Int          @default(1)
  maxProducts  Int          @default(100)
  features     Json?
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  subscriptions       Subscription[]
  planUpgradeRequests PlanUpgradeRequest[]
  checkoutRequests   CheckoutRequest[]

  @@map("plans")
}

model Subscription {
  id           String             @id @default(cuid())
  companyId    String             @map("company_id")
  planId       String             @map("plan_id")
  status       SubscriptionStatus @default(TRIALING)
  provider     PaymentProvider    @default(CASH)
  billingCycle BillingCycle       @default(MONTHLY)
  startDate    DateTime           @map("start_date")
  endDate      DateTime           @map("end_date")
  autoRenew    Boolean            @default(true) @map("auto_renew")
  providerSubscriptionId String?  @map("provider_subscription_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan           Plan           @relation(fields: [planId], references: [id])
  payments      Payment[]
  paymentProofs PaymentProof[]

  @@unique([companyId])
  @@map("subscriptions")
}

model Membership {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  companyId String         @map("company_id")
  role      MembershipRole @default(CASHIER)
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("memberships")
}

model Customer {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  firstName      String   @map("first_name")
  lastName       String?  @map("last_name")
  email          String?
  phone          String?
  documentType   String?  @map("document_type")
  documentValue  String?  @map("document_value")
  address        String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales   Sale[]

  @@map("customers")
}

model Category {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, slug])
  @@map("categories")
}

model Product {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  categoryId    String?  @map("category_id")
  name          String
  sku           String?  @unique
  description   String?
  salePrice     Decimal  @map("sale_price") @db.Decimal(10, 2)
  costPrice     Decimal? @map("cost_price") @db.Decimal(10, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")
  minStock     Int      @default(5) @map("min_stock")
  isActive      Boolean  @default(true) @map("is_active")
  imageUrl      String?  @map("image_url")
  barcode       String?  @unique
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]

  @@map("products")
}

model Sale {
  id             String          @id @default(cuid())
  companyId      String          @map("company_id")
  customerId     String?         @map("customer_id")
  employeeId     String?         @map("employee_id")
  saleNumber     String          @unique @map("sale_number")
  status         SaleStatus      @default(COMPLETED)
  subtotal       Decimal         @db.Decimal(12, 2)
  taxAmount      Decimal         @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal?        @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal         @map("total_amount") @db.Decimal(12, 2)
  paymentMethod  PaymentProvider @default(CASH)
  paidAmount     Decimal         @map("paid_amount") @db.Decimal(12, 2)
  changeAmount   Decimal         @map("change_amount") @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  items    SaleItem[]

  @@map("sales")
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String   @map("sale_id")
  productId  String   @map("product_id")
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  totalPrice Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([saleId, productId])
  @@map("sale_items")
}

model Employee {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  userId    String?  @unique @map("user_id")
  firstName String   @map("first_name")
  lastName  String?  @map("last_name")
  email    String?
  phone    String?
  dni      String?  @unique
  role     MembershipRole @default(CASHIER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user   User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sales  Sale[]

  @@map("employees")
}

model InventoryMovement {
  id        String                @id @default(cuid())
  companyId String                @map("company_id")
  productId String                @map("product_id")
  type      InventoryMovementType
  quantity  Int
  reference String?
  reason    String?
  notes     String?
  createdAt DateTime              @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_movements")
}

model Payment {
  id                String          @id @default(cuid())
  subscriptionId    String          @map("subscription_id")
  amount            Decimal         @db.Decimal(10, 2)
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProvider @default(CASH)
  providerPaymentId String?         @map("provider_payment_id")
  currency          String           @default("PEN")
  providerPayload  Json?
  paidAt            DateTime?       @map("paid_at")
  transactionId     String?         @map("transaction_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PlanUpgradeRequest {
  id            String            @id @default(cuid())
  companyId     String            @map("company_id")
  currentPlanId String?           @map("current_plan_id")
  planId        String            @map("plan_id")
  provider      PaymentProvider?  @default(CASH)
  amount        String?
  currency      String?           @default("PEN")
  status        PlanUpgradeStatus @default(PENDING)
  notes         String?
  proofImageBase64 String?         @map("proof_image_base64")
  paymentDate    DateTime?         @map("payment_date")
  submittedAt   DateTime?         @map("submitted_at")
  reviewedBy    String?           @map("reviewed_by")
  reviewedAt    DateTime?         @map("reviewed_at")
  reviewNotes   String?           @map("review_notes")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id])

  @@map("plan_upgrade_requests")
}

model InvoiceTemplate {
  id        String   @id @default(cuid())
  companyId String?  @map("company_id")
  name      String
  content   String   @db.Text
  isGlobal  Boolean  @default(false) @map("is_global")
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Campos adicionales para configuracion de invoice
  type            String?   @default("BOLETA")
  description     String?
  headerText      String?   @map("header_text")
  logoUrl         String?   @map("logo_url")
  companyRuc      String?   @map("company_ruc")
  companyAddress  String?   @map("company_address")
  companyPhone    String?   @map("company_phone")
  showLogo        Boolean   @default(true) @map("show_logo")
  showCompany     Boolean   @default(true) @map("show_company")
  showCustomer    Boolean   @default(true) @map("show_customer")
  showEmployee    Boolean   @default(false) @map("show_employee")
  showItems       Boolean   @default(true) @map("show_items")
  showSubtotal    Boolean   @default(true) @map("show_subtotal")
  showTax         Boolean   @default(true) @map("show_tax")
  showDiscount    Boolean   @default(true) @map("show_discount")
  showSaleNumber  Boolean   @default(true) @map("show_sale_number")
  showSaleDate    Boolean   @default(true) @map("show_sale_date")
  showSaleTime    Boolean   @default(false) @map("show_sale_time")
  showPaymentMethod Boolean @default(true) @map("show_payment_method")
  footerText      String?   @map("footer_text")
  taxPercentage   Float     @default(18) @map("tax_percentage")
  customFields    Json?     @map("custom_fields")
  fontFamily      String    @default("Arial") @map("font_family")
  fontSize        Int       @default(12) @map("font_size")
  paperSize       String    @default("A4") @map("paper_size")

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("invoice_templates")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  companyId String?             @map("company_id")
  type      NotificationType  @default(SYSTEM)
  channel  NotificationChannel @default(IN_APP)
  title     String
  message   String
  data      Json?
  isRead    Boolean            @default(false) @map("is_read")
  sentAt    DateTime?          @map("sent_at")
  createdAt DateTime          @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String      @map("company_id")
  userId    String?     @map("user_id")
  action    AuditAction
  entity    String
  entityId  String      @map("entity_id")
  changes   Json?
  ipAddress String?    @map("ip_address")
  userAgent String?    @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model PaymentSetting {
  id              String          @id @default(cuid())
  companyId       String          @map("company_id")
  provider        PaymentProvider
  config         Json
  qrImageBase64  String?         @map("qr_image_base64")
  accountNumber  String?         @map("account_number")
  accountName    String?         @map("account_name")
  instructions   String?
  isEnabled     Boolean         @default(true) @map("is_enabled")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@map("payment_settings")
}

model CheckoutRequest {
  id          String              @id @default(cuid())
  companyId   String?            @map("company_id")
  planId     String              @map("plan_id")
  fullName   String              @map("full_name")
  companyName String?            @map("company_name")
  email      String
  passwordHash String            @map("password_hash")
  provider   PaymentProvider
  amount     String
  currency   String            @default("PEN")
  status     CheckoutRequestStatus @default(DRAFT)
  proofImageBase64 String?       @map("proof_image_base64")
  reviewNotes String?           @map("review_notes")
  paymentDate  DateTime?        @map("payment_date")
  submittedAt  DateTime?        @map("submitted_at")
  userId       String?          @map("user_id")
  subscriptionId String?        @map("subscription_id")
  notes      String?
  reviewedAt DateTime?          @map("reviewed_at")
  reviewedBy String?            @map("reviewed_by")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  company Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    Plan     @relation(fields: [planId], references: [id])

  @@map("checkout_requests")
}

model PaymentProof {
  id              String      @id @default(cuid())
  subscriptionId  String      @map("subscription_id")
  imageBase64     String      @map("image_base64")
  amount          String
  paymentDate     DateTime    @map("payment_date")
  status          ProofStatus @default(PENDING)
  reviewedBy      String?     @map("reviewed_by")
  reviewedAt      DateTime?   @map("reviewed_at")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("payment_proofs")
}